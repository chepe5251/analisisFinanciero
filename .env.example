# ─── Backend ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost/reconciliation_db
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
CORS_ORIGINS=["http://localhost:3000"]
AMOUNT_TOLERANCE=0.01
NAME_SIMILARITY_THRESHOLD=0.80

# Seguridad JWT — cambia SECRET_KEY por una cadena larga y aleatoria en producción
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_en_produccion_usa_una_clave_larga_y_aleatoria
ACCESS_TOKEN_EXPIRE_HOURS=8
ALGORITHM=HS256

# Credenciales del admin por defecto (solo se crean si no existen usuarios)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@reconcilaapp.local
DEFAULT_ADMIN_PASSWORD=Admin1234!

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
