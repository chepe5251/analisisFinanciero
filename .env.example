# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env a control de versiones (ya está en .gitignore).

# ─── Base de datos ────────────────────────────────────────────────────────────
POSTGRES_DB=reconciliation_db
POSTGRES_USER=reconcilaapp
POSTGRES_PASSWORD=change_me_secure_password
DATABASE_URL=postgresql://reconcilaapp:change_me_secure_password@db/reconciliation_db

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
CORS_ORIGINS=["http://localhost:3000"]

# Parámetros de conciliación
AMOUNT_TOLERANCE=0.01
NAME_SIMILARITY_THRESHOLD=0.80

# ─── Seguridad JWT ────────────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8
REFRESH_TOKEN_EXPIRE_DAYS=7

# Credenciales del admin por defecto (solo se crean si no existen usuarios)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@reconcilaapp.local
DEFAULT_ADMIN_PASSWORD=Admin1234!

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Storage (vacío = disco local en dev) ─────────────────────────────────────
S3_BUCKET=
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
